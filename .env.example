# Token do bot Discord
# Obtenha em: https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=seu_token_aqui

# URL pública onde o serviço vai rodar (sem barra no final)
# Railway gera isso automaticamente, ex: https://magic-bot.up.railway.app
BASE_URL=https://seu-app.up.railway.app
# Porta (Railway define automaticamente via $PORT)
PORT=8000

# Caminho do banco SQLite (opcional)
# DB_PATH=magic.db
